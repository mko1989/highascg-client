# HighAsCG — omit from squashfs (liveroot-relative paths, no leading /)
# ISO = Caspar shell; Node server from exFAT update/server/ (tools/runtime/ in tarball)
# See docs/WO47_ISO_VS_EXFAT.md

swap.img
swapfile

