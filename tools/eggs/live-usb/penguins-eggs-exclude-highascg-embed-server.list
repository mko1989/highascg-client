# HighAsCG — omit dev trees from squashfs; keep server runtime on ISO (standalone boot).
# Use with HIGHASCG_ISO_EMBED_SERVER=1 in prepare-eggs-clone-with-exfat.sh
# See docs/WO47_ISO_VS_EXFAT.md (exFAT update/server/ still applies when stick present)

swap.img
swapfile

# Browser UI (operator workstation / Electron — not on playout ISO)
home/casparcg/highascg/client
home/casparcg/highascg/client/*
home/casparcg/highascg/dist-web
home/casparcg/highascg/dist-web/*
home/casparcg/highascg/deprecated
home/casparcg/highascg/deprecated/*
home/casparcg/highascg/work
home/casparcg/highascg/work/*
home/casparcg/highascg/examples
home/casparcg/highascg/examples/*
home/casparcg/highascg/samples
home/casparcg/highascg/samples/*
home/casparcg/highascg/scratch
home/casparcg/highascg/scratch/*

# tools/ except runtime/ (exfat-sync, Caspar helpers)
home/casparcg/highascg/tools/eggs
home/casparcg/highascg/tools/eggs/*
home/casparcg/highascg/tools/smoke
home/casparcg/highascg/tools/smoke/*
home/casparcg/highascg/tools/release
home/casparcg/highascg/tools/release/*
home/casparcg/highascg/tools/restore
home/casparcg/highascg/tools/restore/*

# Runtime under ~/highascg (stubs stay on ISO)
home/casparcg/highascg/media/*
home/casparcg/highascg/_media
home/casparcg/highascg/log
home/casparcg/highascg/log/*
home/casparcg/highascg/cef-cache
home/casparcg/highascg/cef-cache/*
home/casparcg/highascg/data
home/casparcg/highascg/data/*
home/casparcg/highascg/refs
home/casparcg/highascg/dist
home/casparcg/highascg/.github
home/casparcg/highascg/.github/*

# exFAT mountpoint (empty in ISO)
home/casparcg/exfat
home/casparcg/exfat/*

# casparcg build-host dotfiles (not .xsession)
home/casparcg/.cache
home/casparcg/.cache/*
home/casparcg/.cursor-server
home/casparcg/.cursor-server/*
home/casparcg/.cursor
home/casparcg/.cursor/*
home/casparcg/.local
home/casparcg/.local/*
home/casparcg/.ssh
home/casparcg/.ssh/*
home/casparcg/.npm
home/casparcg/.npm/*
home/casparcg/.nvm
home/casparcg/.nvm/*
home/casparcg/.config/Code
home/casparcg/.config/Code/*
home/casparcg/.config/Cursor
home/casparcg/.config/Cursor/*
home/casparcg/.config/cursor
home/casparcg/.config/cursor/*

# Tailscale node identity (deb + snap — all common layouts)
var/lib/tailscale
var/lib/tailscale/*
var/snap/tailscale
var/snap/tailscale/*
snap/tailscale
snap/tailscale/*
root/snap/tailscale
root/snap/tailscale/*
