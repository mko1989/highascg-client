# --- WO-47 exFAT mount stub (empty mountpoint in ISO — no builder scratch on media) ---
# Runtime: systemd mounts LABEL=HIGHASCGEXF at `/home/casparcg/exfat`. Exclude any stray files created on the dev host.
home/casparcg/exfat/*

