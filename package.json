{
	"name": "highascg-client",
	"version": "2026.05.20",
	"description": "HighAsCG operator UI and Electron launcher (talks to playout API over HTTP/WebSocket)",
	"type": "commonjs",
	"scripts": {
		"dev": "vite",
		"dev:client": "vite",
		"build": "vite build",
		"assets:optimize": "bash client/tools/optimize-brand-assets.sh",
		"build:client": "vite build",
		"launcher:prepare": "npx vite build && bash client/tools/electron-launcher/sync-dist-web.sh && bash client/tools/electron-launcher/sync-launcher-bundle.sh && bash client/tools/electron-launcher/sync-sim-server.sh",
		"launcher:bundle": "bash client/tools/electron-launcher/sync-dist-web.sh && bash client/tools/electron-launcher/sync-launcher-bundle.sh",
		"launcher:sim-install": "npm install --prefix client/tools/electron-launcher/sim-server",
		"launcher": "bash client/tools/electron-launcher/sync-dist-web.sh && bash client/tools/electron-launcher/sync-launcher-bundle.sh && electron --no-sandbox client/tools/electron-launcher",
		"build:launcher": "bash client/tools/release/build-launcher-packages.sh",
		"release:github-client": "bash client/tools/release/make-github-release-client.sh",
		"release:github-client:dry": "bash client/tools/release/make-github-release-client.sh --dry-run",
		"release:github-launcher": "bash client/tools/release/make-github-release-launcher.sh --client-tarball-too",
		"release:github-launcher:dry": "bash client/tools/release/make-github-release-launcher.sh --dry-run --client-tarball-too",
		"portable:sim": "HIGHASCG_LAUNCHER_DIR=client/tools/electron-launcher node client/tools/portable-desktop/launch-sim-from-exfat.cjs",
		"portable:sim:check": "node --check client/tools/portable-desktop/launch-sim-from-exfat.cjs && node --check client/tools/portable-desktop/sim-app-root.cjs",
		"operator-kit": "node client/tools/operator-desktop/highascg-operator.js",
		"operator-kit:check": "node --check client/tools/operator-desktop/highascg-operator.js",
		"stick-studio": "python3 client/tools/stick-tools/stick_studio.py"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"electron": "^30.0.0",
		"vite": "^6.4.2"
	},
	"optionalDependencies": {
		"grapesjs": "^0.21.2",
		"html-to-image": "^1.11.13",
		"three": "^0.184.0"
	}
}
