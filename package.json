{
	"name": "highascg",
	"version": "0.1.0",
	"description": "HighAsCG — standalone CasparCG control server (migrated from companion-module-casparcg-server)",
	"type": "commonjs",
	"main": "index.js",
	"scripts": {
		"start": "node index.js",
		"dev": "node --watch index.js",
		"deploy:dev": "bash scripts/dev-push.sh",
		"smoke": "node tools/http-smoke.js",
		"smoke:caspar": "node tools/smoke-caspar.js",
		"smoke:previs-uv": "node tools/smoke-previs-uv.mjs",
		"smoke:previs-state": "node tools/smoke-previs-state.mjs",
		"smoke:previs-stream": "node tools/smoke-previs-stream.mjs",
		"smoke:previs-texture-crop": "node tools/smoke-previs-texture-crop.mjs",
		"smoke:usb-lsblk": "node --test tools/smoke-usb-lsblk.js",
		"smoke:media-mount": "node --test tools/smoke-media-mount-lsblk.js",
		"exfat-sync": "node tools/exfat-sync-cli.js",
		"smoke:exfat-sync": "node --test tools/smoke-exfat-sync.js",
    "test:device-graph": "node --test tools/smoke-device-graph.js",
		"test:device-snapshot": "node --test tools/smoke-device-snapshot.js",
		"test:os-layout-w40": "node --test tools/smoke-os-layout-w40.js",
		"test:mapping-gpu-os-layout": "node --test tools/smoke-mapping-gpu-os-layout.js",
		"test:xrandr-custom-mode": "node --test tools/smoke-xrandr-custom-mode.js",
		"test:modeline-timings": "node --test tools/smoke-modeline-timings.js",
		"test:config-generator": "node --test tools/smoke-config-generator-routing.js",
		"test:playlist": "node --test tools/smoke-playlist.js",
		"smoke:companion-press": "node tools/smoke-companion-press.mjs",
		"smoke:streaming-ch": "node tools/verify-streaming-channel.mjs",
		"amcp:test": "node tools/amcp-tester.js",
		"test:highascg": "node --test tools/highascg-health-api-amcp.test.js",
		"test:highascg:live": "node --test tools/highascg-live-amcp.test.js",
		"test:highascg:live:http": "node --test tools/highascg-live-highascg-http.test.js",
		"test:highascg:live:all": "node --test tools/highascg-live-amcp.test.js tools/highascg-live-highascg-http.test.js",
		"install:base": "npm install --omit=optional",
		"install:previs": "npm install --include=optional",
		"install:cg-studio": "npm install --no-save grapesjs",
		"portable:sim": "node tools/portable-desktop/launch-sim-from-exfat.js",
		"portable:sim:check": "node --check tools/portable-desktop/launch-sim-from-exfat.js",
		"operator-kit": "node tools/operator-desktop/highascg-operator.js",
		"operator-kit:check": "node --check tools/operator-desktop/highascg-operator.js",
		"stick-studio": "python3 tools/stick-tools/stick_studio.py",
		"launcher": "python3 tools/operator-desktop/highascg-launcher.py",
		"release:dev-github": "bash tools/release/make-dev-github-release.sh",
		"release:dev-github:dry": "bash tools/release/make-dev-github-release.sh --dry-run",
		"release:github-app": "bash tools/release/make-dev-github-release.sh --app-only",
		"release:github-app:dry": "bash tools/release/make-dev-github-release.sh --app-only --dry-run",
		"smoke:wo47-manifest": "node tools/smoke-wo47-manifest.mjs"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"busboy": "^1.6.0",
		"dmxnet": "^0.9.0",
		"html-to-image": "^1.11.13",
		"osc": "^2.4.5",
		"sacn": "^4.6.2",
		"unzipper": "^0.12.3",
		"wetransfert": "^2.4.0",
		"ws": "^8.18.0",
		"xml2js": "^0.6.2"
	},
	"optionalDependencies": {
		"grapesjs": "^0.21.2",
		"naudiodon": "^2.3.6",
		"onnxruntime-node": "^1.24.3",
		"three": "^0.184.0"
	}
}
