{
	"name": "highascg",
	"version": "2026.05.20",
	"description": "HighAsCG — standalone CasparCG control server (migrated from companion-module-casparcg-server)",
	"type": "commonjs",
	"main": "index.js",
	"scripts": {
		"start": "HIGHASCG_HEADLESS=true node index.js",
		"dev": "HIGHASCG_HEADLESS=true node --watch index.js",
		"start:monolith": "node index.js",
		"dev:monolith": "node --watch index.js",
		"dev:client": "vite",
		"build:client": "vite build",
		"deploy:dev": "bash client/scripts/dev-push.sh",
		"deploy:dev:client": "DEPLOY_BUILD_CLIENT=1 bash client/scripts/dev-push.sh",
		"clean:eggs-host": "bash scripts/clean-eggs-dev-host.sh",
		"verify:structure": "node tools/eggs/verify-w02-structure.js",
		"exfat-sync": "node tools/runtime/exfat-sync-cli.js",
		"smoke": "node tools/smoke/http-smoke.js",
		"smoke:caspar": "node tools/smoke/smoke-caspar.js",
		"smoke:previs-uv": "node tools/smoke/smoke-previs-uv.mjs",
		"smoke:previs-state": "node tools/smoke/smoke-previs-state.mjs",
		"smoke:previs-stream": "node tools/smoke/smoke-previs-stream.mjs",
		"smoke:previs-texture-crop": "node tools/smoke/smoke-previs-texture-crop.mjs",
		"smoke:usb-lsblk": "node --test tools/smoke/smoke-usb-lsblk.js",
		"smoke:media-mount": "node --test tools/smoke/smoke-media-mount-lsblk.js",
		"smoke:exfat-sync": "node --test tools/smoke/smoke-exfat-sync.js",
		"test:device-graph": "node --test tools/smoke/smoke-device-graph.js",
		"test:device-snapshot": "node --test tools/smoke/smoke-device-snapshot.js",
		"test:os-layout-w40": "node --test tools/smoke/smoke-os-layout-w40.js",
		"test:mapping-gpu-os-layout": "node --test tools/smoke/smoke-mapping-gpu-os-layout.js",
		"test:xrandr-custom-mode": "node --test tools/smoke/smoke-xrandr-custom-mode.js",
		"test:modeline-timings": "node --test tools/smoke/smoke-modeline-timings.js",
		"test:config-generator": "node --test tools/smoke/smoke-config-generator-routing.js",
		"test:playlist": "node --test tools/smoke/smoke-playlist.js",
		"smoke:companion-press": "node tools/smoke/smoke-companion-press.mjs",
		"smoke:streaming-ch": "node tools/smoke/verify-streaming-channel.mjs",
		"smoke:wo47-manifest": "node tools/smoke/smoke-wo47-manifest.mjs",
		"smoke:api-origin": "node tools/smoke/smoke-api-origin.mjs",
		"test:highascg": "node --test tools/smoke/highascg-health-api-amcp.test.js",
		"test:highascg:live": "node --test tools/smoke/highascg-live-amcp.test.js",
		"test:highascg:live:http": "node --test tools/smoke/highascg-live-highascg-http.test.js",
		"test:highascg:live:all": "node --test tools/smoke/highascg-live-amcp.test.js tools/smoke/highascg-live-highascg-http.test.js",
		"install:base": "npm install --omit=optional",
		"install:previs": "npm install --include=optional",
		"install:cg-studio": "npm install --no-save grapesjs",
		"portable:sim": "node client/tools/portable-desktop/launch-sim-from-exfat.js",
		"portable:sim:check": "node --check client/tools/portable-desktop/launch-sim-from-exfat.js",
		"operator-kit": "node client/tools/operator-desktop/highascg-operator.js",
		"operator-kit:check": "node --check client/tools/operator-desktop/highascg-operator.js",
		"stick-studio": "python3 client/tools/stick-tools/stick_studio.py",
		"launcher:prepare": "npx vite build && bash client/tools/electron-launcher/sync-dist-web.sh",
		"launcher": "electron --no-sandbox client/tools/electron-launcher",
		"release:github-server": "bash tools/release/make-github-release-server.sh",
		"release:github-server:dry": "bash tools/release/make-github-release-server.sh --dry-run",
		"release:github-client": "bash client/tools/release/make-github-release-client.sh",
		"release:github-client:dry": "bash client/tools/release/make-github-release-client.sh --dry-run",
		"release:github-launcher": "bash tools/release/make-github-release-launcher.sh",
		"release:github-launcher:dry": "bash tools/release/make-github-release-launcher.sh --dry-run",
		"release:github-app": "bash deprecated/tools/release/make-dev-github-release.sh --app-only",
		"release:github-app:dry": "bash deprecated/tools/release/make-dev-github-release.sh --app-only --dry-run",
		"build:launcher": "npm run launcher:prepare && npx @electron/packager client/tools/electron-launcher HighAsCG-Launcher --platform=linux,win32,darwin --arch=x64,arm64 --out=dist/launcher --overwrite",
		"build:launcher:dry": "npx @electron/packager client/tools/electron-launcher HighAsCG-Launcher --platform=linux --arch=x64,arm64 --out=dist/launcher --overwrite --dry-run",
		"eggs:prepare": "sudo bash tools/eggs/live-usb/prepare-eggs-clone-with-exfat.sh",
		"eggs:build": "sudo bash tools/eggs/live-usb/build-highascg-egg.sh"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"busboy": "^1.6.0",
		"dmxnet": "^0.9.0",
		"html-to-image": "^1.11.13",
		"osc": "^2.4.5",
		"sacn": "^4.6.2",
		"unzipper": "^0.12.3",
		"wetransfert": "^2.4.0",
		"ws": "^8.18.0",
		"xml2js": "^0.6.2"
	},
	"devDependencies": {
		"electron": "^30.0.0",
		"vite": "^6.4.2"
	},
	"optionalDependencies": {
		"grapesjs": "^0.21.2",
		"naudiodon": "^2.3.6",
		"onnxruntime-node": "^1.24.3",
		"three": "^0.184.0"
	}
}
