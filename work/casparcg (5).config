<configuration>
    <paths>
        <media-path>media/</media-path>
        <log-path disable="false">log/</log-path>
        <data-path>data/</data-path>
        <template-path>template/</template-path>
    </paths>
    <lock-clear-phrase>secret</lock-clear-phrase>
    <log-level>info</log-level>
    <system-audio>
        <device-name/>
    </system-audio>
    <channels>
        <channel>
            <video-mode>5120x768</video-mode>
            <channel-layout>stereo</channel-layout>
            <consumers>
                <screen>
                    <device>1</device>
                    <enable-mipmaps>true</enable-mipmaps>
                    <stretch>none</stretch>
                    <windowed>true</windowed>
                    <key-only>false</key-only>
                    <vsync>false</vsync>
                    <borderless>false</borderless>
                    <interactive>false</interactive>
                    <always-on-top>true</always-on-top>
                    <x>0</x><y>0</y>
                    <width>5120</width><height>768</height>
                    <sbs-key>false</sbs-key>
                    <colour-space>RGB</colour-space>
                    <force-linear-filter>true</force-linear-filter>
                </screen>
                <system-audio />
                <ffmpeg>
                    <path>udp://127.0.0.1:40001?localport=50001</path>
                    <args>-filter:v scale=w=iw/2:h=ih/2,format=yuv420p,fps=25 -codec:v libx264 -preset:v ultrafast -tune:v zerolatency -b:v 2000k -g:v 50 -x264-params:v min-keyint=25:scenecut=0:repeat-headers=1 -filter:a aformat=channel_layouts=stereo,aresample=48000 -codec:a aac -b:a 128k -format mpegts</args>
                </ffmpeg>
                <decklink>
                    <device>4</device>
                </decklink>
                <ndi>
                    <name>HighAsCG-CH1</name>
                </ndi>
            </consumers>
            <mixer>
                <audio-osc>true</audio-osc>
            </mixer>
        </channel>
        <channel>
            <video-mode>5120x768</video-mode>
            <consumers>
                <ffmpeg>
                    <path>udp://127.0.0.1:40002?localport=50002</path>
                    <args>-filter:v scale=w=iw/2:h=ih/2,format=yuv420p,fps=25 -codec:v libx264 -preset:v ultrafast -tune:v zerolatency -b:v 2000k -g:v 50 -x264-params:v min-keyint=25:scenecut=0:repeat-headers=1 -filter:a aformat=channel_layouts=stereo,aresample=48000 -codec:a aac -b:a 128k -format mpegts</args>
                </ffmpeg></consumers>
            <mixer>
                <audio-osc>true</audio-osc>
            </mixer>
        </channel>
        <channel>
            <video-mode>1080p5000</video-mode>
            <consumers>
                <screen>
                    <device>2</device>
                    <x>5120</x><y>0</y>
                    <width>1920</width><height>1080</height>
                    <stretch>none</stretch>
                    <windowed>true</windowed>
                    <vsync>false</vsync>
                    <always-on-top>true</always-on-top>
                    <borderless>false</borderless>
                </screen>
                <ffmpeg>
                    <path>udp://127.0.0.1:40003?localport=50003</path>
                    <args>-filter:v scale=w=iw/2:h=ih/2,format=yuv420p,fps=25 -codec:v libx264 -preset:v ultrafast -tune:v zerolatency -b:v 2000k -g:v 50 -x264-params:v min-keyint=25:scenecut=0:repeat-headers=1 -filter:a aformat=channel_layouts=stereo,aresample=48000 -codec:a aac -b:a 128k -format mpegts</args>
                </ffmpeg>
            </consumers>
            <mixer>
                <audio-osc>false</audio-osc>
            </mixer>
        </channel>
    </channels>
    <video-modes>
        <video-mode>
            <id>5120x768</id>
            <width>5120</width>
            <height>768</height>
            <time-scale>50000</time-scale>
            <duration>1000</duration>
            <cadence>960</cadence>
        </video-mode>
    </video-modes>
    <controllers><tcp><port>5250</port><protocol>AMCP</protocol></tcp>
    </controllers>
    <osc>
        <default-port>6250</default-port>
        <disable-send-to-amcp-clients>false</disable-send-to-amcp-clients>
        <predefined-clients>
            <predefined-client>
                <address>127.0.0.1</address>
                <port>6251</port>
            </predefined-client>
        </predefined-clients>
    </osc>

    <amcp><media-server><host>localhost</host><port>8000</port></media-server></amcp>
    <ndi><auto-load>true</auto-load></ndi>
    <decklink/>
    <html>
        <enable-gpu>true</enable-gpu>
        <command-line-args>--enable-features=PartitionAlloc --js-flags=--max-old-space-size=512</command-line-args>
    </html>
</configuration>