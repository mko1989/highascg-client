/* Allow users in group "plugdev" to mount/unmount/power-off removable media without a password.
 * Install: sudo cp scripts/polkit/50-highascg-udisks.rules /etc/polkit-1/rules.d/
 *          sudo systemctl restart polkit (or reboot)
 * Replace plugdev with your HighAsCG service group if different.
 */
polkit.addRule(function (action, subject) {
    if (
        action.id.indexOf('org.freedesktop.udisks2.') === 0 &&
        subject.local &&
        subject.active &&
        subject.isInGroup('plugdev')
    ) {
        return polkit.Result.YES;
    }
});
